{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "persistent-2d-world-test",
  "main": "worker.js",
  "compatibility_date": "2026-07-15",
  "durable_objects": {
    "bindings": [
      {
        "name": "WORLD",
        "class_name": "SharedWorld"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SharedWorld"]
    }
  ],
  "observability": {
    "enabled": true
  }
}

